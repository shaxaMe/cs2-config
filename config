# cs2-config
// Mouse settings
sensitivity 1.5
zoom_sensitivity_ratio 1
m_rawinput 1
// Crosshair (simple va aniq)
cl_crosshairsize 2.5
cl_crosshairthickness 0.5
cl_crosshairgap -2
cl_crosshair_drawoutline 0
cl_crosshaircolor 5
cl_crosshaircolor_r 0
cl_crosshaircolor_g 255
cl_crosshaircolor_b 0
