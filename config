cl_radar_scale 0.4
cl_hud_radar_scale 1.15
cl_radar_icon_scale_min 0.6
// FPS optimizatsiya
fps_max 0
// Net settings
rate 786432
cl_interp 0
cl_interp_ratio 1
cl_cmdrate 128
cl_updaterate 128
